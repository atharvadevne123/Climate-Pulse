# Climate-Pulse Environment Configuration
# Copy to .env and fill in your values.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://climatepulse:climatepulse@localhost:5432/climatepulse

# SQLite (local dev — remove DATABASE_URL above to use this)
# DATABASE_URL=sqlite:///./climate_pulse.db

# Connection pool settings (PostgreSQL only; ignored for SQLite)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ─── Model storage ────────────────────────────────────────────────────────────
# Directory where joblib model bundles are persisted (created automatically)
MODEL_DIR=./models

# ─── API settings ─────────────────────────────────────────────────────────────
# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max requests per minute per IP address (sliding window)
RATE_LIMIT_PER_MINUTE=200

# Enable FastAPI debug mode (do NOT set true in production)
DEBUG=false

# ─── Alembic / migrations ─────────────────────────────────────────────────────
# Used by alembic.ini if ALEMBIC_CONFIG_URL is set
# ALEMBIC_CONFIG_URL=postgresql://climatepulse:climatepulse@localhost:5432/climatepulse

# ─── Docker Compose ───────────────────────────────────────────────────────────
# Overrides for docker-compose.yml (PostgreSQL service)
POSTGRES_DB=climatepulse
POSTGRES_USER=climatepulse
POSTGRES_PASSWORD=climatepulse
